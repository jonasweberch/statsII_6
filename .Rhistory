library(skimr)
# Summarize the data
skim(df)
# Load required packages
library(skimr)
# Load the data set
df <- read.csv("careworkers_did.csv", sep=";")
# Summarize the data
skim(df)
# Replace invalid values with NA
df$CAREWORKERS[df$CAREWORKERS == -9999999] <- NA
df$YIAR[df$YIAR == -1] <- NA
# Summarize cleaned data
skim(df)
# Shorten country names
df$COUNTRY <- gsub("Country ", "", df$COUNTRY)
# Count missing values
colSums(is.na(df))
# Rename column
names(df)[names(df) == "YIAR"] <- "YEAR"
# Create POST dummy
df$POST <- ifelse(df$YEAR > 1992, 1, 0)
# Create TREATED dummy
df$TREATED <- ifelse(df$COUNTRY == "A", 1, 0)
avg_df <- aggregate(CAREWORKERS ~ YEAR + COUNTRY,
data = df,
mean)
library(ggplot2)
ggplot(avg_df,
aes(x = YEAR,
y = CAREWORKERS,
color = COUNTRY)) +
geom_line(size = 1.2) +
geom_vline(xintercept = 1992,
linetype = "dashed") +
labs(title = "Parallel Trends Assumption",
y = "Careworkers per 100 inhabitants")
avg_df <- aggregate(CAREWORKERS ~ YEAR + COUNTRY,
data = df,
mean)
library(ggplot2)
ggplot(avg_df,
aes(x = YEAR,
y = CAREWORKERS,
color = COUNTRY)) +
geom_line(size = 1.2) +
geom_vline(xintercept = 1992,
linetype = "dashed") +
labs(title = "Parallel Trends Assumption",
y = "Careworkers per 100 inhabitants")
library(ggplot2)
ggplot(avg_df,
aes(x = YEAR,
y = CAREWORKERS,
color = COUNTRY)) +
