y = "Careworkers per 100 inhabitants")
# Load required packages
library(skimr)
library(ggplot2)
ggplot(avg_df,
aes(x = YEAR,
y = CAREWORKERS,
color = COUNTRY)) +
geom_line(size = 1.2) +
geom_vline(xintercept = 1993,
linetype = "dashed") +
labs(title = "",
y = "Careworkers per 100 inhabitants")
ggplot(avg_df,
aes(x = YEAR,
y = CAREWORKERS,
color = COUNTRY)) +
geom_line(size = 1.2) +
geom_vline(xintercept = 1993,
linetype = "dashed") +
labs(title = "Countries A and B Exhibit Parallel Trends Before 1993",
y = "Careworkers per 100 inhabitants")
did_model <- lm(CAREWORKERS ~ TREATED + POST + TREATED:POST,
data = df)
summary(did_model)
avg_df <- aggregate(CAREWORKERS ~ YEAR + COUNTRY,
data = df,
mean)
# Create period variable
avg_df$PERIOD <- ifelse(avg_df$YEAR < 1993,
"Before 1993",
"After 1993")
ggplot(avg_df,
aes(x = YEAR,
y = CAREWORKERS,
color = COUNTRY,
linetype = PERIOD)) +
geom_line(linewidth = 1.2) +
geom_vline(xintercept = 1993,
linetype = "dotted") +
labs(title = "Countries A and B Exhibit Parallel Trends Before 1993",
y = "Careworkers per 100 inhabitants")
avg_df <- aggregate(CAREWORKERS ~ YEAR + COUNTRY,
data = df,
mean)
ggplot(avg_df,
aes(x = YEAR,
y = CAREWORKERS,
color = COUNTRY)) +
geom_line(size = 1.2) +
geom_vline(xintercept = 1993,
linetype = "dashed") +
labs(title = "Countries A and B Exhibit Parallel Trends Before 1993",
y = "Careworkers per 100 inhabitants")
did_model <- lm(CAREWORKERS ~ TREATED + POST + TREATED:POST,
data = df)
summary(did_model)
pre_df <- subset(df, YEAR < 1993)
parallel_model <- lm(CAREWORKERS ~ YEAR * TREATED,
data = pre_df)
summary(parallel_model)
#Setup DiD regression
pre_df <- subset(df, YEAR < 1993)
parallel_model <- lm(CAREWORKERS ~ YEAR * TREATED,
data = pre_df)
summary(parallel_model)
